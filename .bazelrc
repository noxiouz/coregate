build --enable_platform_specific_config

# Rust
build --@rules_rust//rust/toolchain/channel=stable

# Test
test --test_output=errors

# musl static builds
build:musl --platforms=//:linux_x86_64_musl
build:musl --extra_toolchains=@rust_toolchains//:rust_linux_x86_64__x86_64-unknown-linux-musl__stable
